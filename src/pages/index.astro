---
import Layout from '../layouts/Layout.astro';
import ProjectCarousel from '../components/ProjectCarousel.astro';
import TechCarousel from '../components/TechCarousel.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import SkillItem from '../components/SkillItem.astro';
import { SITE_CONFIG, PROJECTS, EXPERIENCE, SKILLS } from '../data/config';
import { useTranslations } from '../i18n/ui';

const t = useTranslations('en'); // Defaults to 'en'

function resolvePublicAsset(path: string): string {
  if (!path.startsWith('/')) return path;
  const filename = path.slice(1);
  return import.meta.env.DEV
    ? `${import.meta.env.BASE_URL}${filename}`
    : `https://Superkorlas.github.io/about-me/${filename}`;
}
---

<Layout>
	<section class="container hero-section">
    <div class="hero-content">
      <div class="hero-text">
        <h1 style="font-size: 4rem; line-height: 1.1; margin-bottom: 1.5rem; font-weight: 700;">
          {t('hero.title')} <span class="text-gradient">{t('site.author')}</span>
        </h1>
        <h2 style="font-size: 2rem; font-weight: 500; color: var(--text-muted); margin-bottom: 2rem;">
          {t('hero.subtitle')}
        </h2>
        <p style="font-size: 1.25rem; color: var(--text-muted); max-width: 600px; line-height: 1.8;">
          {t('hero.description')}
        </p>
      </div>
      {SITE_CONFIG.photoUrl && (
        <div class="hero-photo-wrapper">
          <img
            src={resolvePublicAsset(SITE_CONFIG.photoUrl)}
            alt={t('site.author')}
            class="hero-photo"
            loading="eager"
          />
        </div>
      )}
    </div>
	</section>

  <section class="container" style="padding-top: 2rem; padding-bottom: 3rem;">
    <p style="font-size: 0.8rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1.5rem;">
      {t('tech.title')}
    </p>
    <TechCarousel />
  </section>

  <section class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
    <h2 style="font-size: 2.5rem; font-weight: 600; margin-bottom: 3rem; display: inline-block; position: relative;">
      {t('experience.title')}
      <div style="position: absolute; bottom: -10px; left: 0; width: 50px; height: 4px; background: var(--primary-color); border-radius: 2px;"></div>
    </h2>

    <div style="max-width: 800px; margin-left: 1rem;">
      {EXPERIENCE.map(experience => (
        <ExperienceItem experience={experience} />
      ))}
    </div>
  </section>

  <section class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
    <h2 style="font-size: 2.5rem; font-weight: 600; margin-bottom: 3rem; display: inline-block; position: relative;">
      {t('skills.title')}
      <div style="position: absolute; bottom: -10px; left: 0; width: 50px; height: 4px; background: var(--primary-color); border-radius: 2px;"></div>
    </h2>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
      {SKILLS.map(skill => (
        <SkillItem skill={skill} />
      ))}
    </div>
  </section>

  <section class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
    <h2 style="font-size: 2.5rem; font-weight: 600; margin-bottom: 3rem; display: inline-block; position: relative;">
      {t('projects.title')}
      <div style="position: absolute; bottom: -10px; left: 0; width: 50px; height: 4px; background: var(--primary-color); border-radius: 2px;"></div>
    </h2>

    <ProjectCarousel projects={PROJECTS} />
  </section>
</Layout>

<style>
  .hero-section {
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 900px;
  }

  .hero-text {
    flex: 1;
  }

  .hero-photo-wrapper {
    flex-shrink: 0;
  }

  .hero-photo {
    width: 13.75rem;
    height: 13.75rem;
    border-radius: 50%;
    object-fit: cover;
    border: 0.2rem solid var(--card-border);
    box-shadow: 0 0 2rem rgba(99, 102, 241, 0.25);
  }

  @media (max-width: 640px) {
    .hero-section {
      padding-top: 4rem;
    }

    .hero-content {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .hero-photo-wrapper {
      align-self: center;
    }

    .hero-photo {
      width: 7.5rem;
      height: 7.5rem;
    }
  }
</style>
