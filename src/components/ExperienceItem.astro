---
import { useTranslations } from '../i18n/ui';

interface Props {
  experience: {
    id: string;
    roleKey: string;
    descriptionKeys: readonly string[];
  };
}

const { experience } = Astro.props;
const t = useTranslations('en'); // Defaults to 'en'
---
<div class="glass-panel" style="margin-bottom: 2.5rem; padding: 2rem; position: relative;">
  <div style="margin-bottom: 1rem;">
    <h3 style="font-size: 1.5rem; font-weight: 600; margin: 0; color: var(--text-color);">
      {t(experience.roleKey as any)}
    </h3>
  </div>
  <ul style="color: var(--text-muted); line-height: 1.6; padding-left: 1.2rem; margin-top: 1rem;">
    {experience.descriptionKeys.map((key) => (
      <li style="margin-bottom: 0.5rem;">{t(key as any)}</li>
    ))}
  </ul>
</div>
