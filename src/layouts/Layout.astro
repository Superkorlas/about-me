---
import "../styles/global.css";
import { SITE_CONFIG } from "../data/config";
import { ICONS } from "../data/icons";
import { defaultLang, useTranslations } from "../i18n/ui";
import IconImg from "../components/IconImg.astro";
import { resolvePublicAsset } from "../utils/assets";
import ContactForm from "../components/ContactForm";

const t = useTranslations(defaultLang);

interface Props {
    title?: string;
    description?: string;
}

const { title = t("site.title"), description = t("site.description") } =
    Astro.props;

const themeUrl = resolvePublicAsset('/theme.css');
---

<!DOCTYPE html>
<html lang={defaultLang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="icon"
            type="image/png"
            href={`${import.meta.env.BASE_URL}fire-softworks.PNG`}
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link rel="stylesheet" href={themeUrl} />
    </head>
    <body>
        <header
            class="container"
            style="padding-top: 2rem; padding-bottom: 2rem;"
        >
            <nav
                style="display: flex; justify-content: space-between; align-items: center;"
            >
                <div
                    style="font-weight: 700; font-size: 1.5rem;"
                    class="text-gradient"
                >
                    {t("site.author")}
                </div>
                <div class="nav-links">
                    <a href={SITE_CONFIG.itchio} target="_blank" rel="noopener noreferrer" aria-label="Itch.io" title="Itch.io">
                        <IconImg src={ICONS.nav.itchio} alt="Itch.io" width={20} height={20} />
                    </a>
                    <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
                        <IconImg src={ICONS.nav.github} alt="GitHub" width={20} height={20} />
                    </a>
                    <a href={SITE_CONFIG.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
                        <IconImg src={ICONS.nav.linkedin} alt="LinkedIn" width={20} height={20} />
                    </a>
                </div>
            </nav>
        </header>
        <main style="flex: 1;">
            <slot />
        </main>
        <footer
            class="container"
            style="padding-top: 4rem; padding-bottom: 2rem; text-align: center; color: var(--text-muted);"
        >
            <img
                src={`${import.meta.env.BASE_URL}fire-softworks.PNG`}
                alt="Fire Softworks logo"
                class="footer-logo"
            />
            <p>
                &copy; {new Date().getFullYear()}
                {t("site.author")}. All rights reserved.
            </p>
        </footer>
        <ContactForm client:load />
    </body>
</html>

<style>
    .footer-logo {
        width: 4rem;
        height: 4rem;
        object-fit: contain;
        margin-bottom: 1rem;
        opacity: 0.8;
    }

    .nav-links {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    .nav-links a {
        display: flex;
        align-items: center;
        opacity: 0.7;
        transition: opacity 0.2s ease;
    }

    .nav-links a:hover {
        opacity: 1;
    }
</style>
